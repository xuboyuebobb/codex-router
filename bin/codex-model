#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done

ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

if [ "$#" -eq 0 ] || [ "${1:-}" = "list" ]; then
  exec "$ROOT/bin/codex-router" model list
fi

exec "$ROOT/bin/codex-router" model use "$1"
